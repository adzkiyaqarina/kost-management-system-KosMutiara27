' ===================================================================
' BOUNDARY CLASSES (View)
' ===================================================================

package "Boundary Layer" #FDF5E6 {
    
    class LoginView <<boundary>> {
        +renderForm()
        +validateInput()
        +showError()
        +redirectOnSuccess()
    }
    
    class RegisterView <<boundary>> {
        +renderForm()
        +validateInput()
        +showError()
        +redirectOnSuccess()
    }
    
    class AdminDashboardView <<boundary>> {
        +renderStatsCards()
        +renderRecentTransactions()
        +renderOccupancyChart()
        +renderRevenueChart()
        +renderDueTenantsPanel()
