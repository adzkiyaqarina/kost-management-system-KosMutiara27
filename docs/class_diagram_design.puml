AdminAccountController ..> TenantProfile

AdminNotificationController ..> Notification

OwnerRoomController ..> Room
OwnerRoomController ..> RoomType

OwnerRoomTypeController ..> RoomType

OwnerTenantController ..> User
OwnerTenantController ..> Transaction

